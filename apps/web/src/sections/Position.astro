---
import ButtonOption from '../components/ButtonOption.astro';
import CodeBlock from '../components/CodeBlock.astro';
import P from '../components/P.astro';
import Title from '../components/Title.astro';

const positions = [
  { label: 'Top Left',      x: 'left',   y: 'top'    },
  { label: 'Top Center',    x: 'center', y: 'top'    },
  { label: 'Top Right',     x: 'right',  y: 'top'    },
  { label: 'Bottom Left',   x: 'left',   y: 'bottom' },
  { label: 'Bottom Center', x: 'center', y: 'bottom' },
  { label: 'Bottom Right',  x: 'right',  y: 'bottom' },
];
---

<section class="mt-14">
  <Title>Position</Title>
  <P>Swipe direction changes depending on the position.</P>
  <div class="mt-4 flex flex-wrap gap-2">
    {positions.map(({ label, x, y }) => (
      <ButtonOption data-pos={`${y}-${x}`}>{label}</ButtonOption>
    ))}
  </div>
  <div class="mt-4">
    <CodeBlock code='<Toaster position="bottom-right" />' data-position-preview />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { getToastOpts, setPosition } from '../preview-state';

  const btns = document.querySelectorAll<HTMLElement>('[data-pos]');
  const preview = document.querySelector<any>('[data-position-preview]');

  const ACTIVE = { boxShadow: 'rgba(0,0,0,0.2) 0px 0px 0px 1.5px', background: '#f5f5f5' };
  const IDLE   = { boxShadow: 'rgb(235,235,235) 0px 0px 0px 1px',   background: '#ffffff' };

  function setActive(pos: string) {
    btns.forEach((b) => Object.assign(b.style, b.dataset.pos === pos ? ACTIVE : IDLE));
  }

  function updatePreview(pos: string) {
    preview?.setCode?.(`<Toaster position="${pos}" />`);
  }

  setActive('bottom-right');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const pos = btn.dataset.pos as string;
      setPosition(pos);
      setActive(pos);
      updatePreview(pos);
      toast.dismiss();
      toast('Event has been created', {
        description: 'Monday, January 3rd at 6:00pm',
        ...getToastOpts(),
      });
    });
  });
</script>

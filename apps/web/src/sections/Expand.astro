---
import ButtonOption from '../components/ButtonOption.astro';
import CodeBlock from '../components/CodeBlock.astro';
import P from '../components/P.astro';
import Title from '../components/Title.astro';
---

<section class="mt-14">
  <Title>Expand</Title>
  <P>You can change the amount of toasts visible through the <code style="font-family:inherit;background:var(--surface);border-radius:4px;padding:1px 5px;font-size:12px">visibleToasts</code> prop.</P>
  <div class="mt-4 flex flex-wrap gap-2">
    <ButtonOption data-expand="true">Expand</ButtonOption>
    <ButtonOption data-expand="false">Default</ButtonOption>
  </div>
  <div class="mt-4">
    <CodeBlock code="<Toaster expand={false} /> // default" data-expand-preview />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { getToastOpts } from '../preview-state';

  const btns = document.querySelectorAll<HTMLElement>('[data-expand]');
  const preview = document.querySelector<any>('[data-expand-preview]');

  function setActive(activeExpand: boolean) {
    btns.forEach((b) => { b.dataset.active = String(b.dataset.expand === String(activeExpand)); });
  }

  function updatePreview(expand: boolean) {
    if (expand) {
      preview?.setCode?.(`<Toaster expand={true} />`);
    } else {
      preview?.setCode?.(`<Toaster expand={false} /> // default`);
    }
  }

  function applyExpandToToaster(expand: boolean) {
    const root = document.querySelector<any>('section[data-sonner-root]');
    const inst = root?.__sonnerInstance as any;
    if (!inst) return;
    inst.opts.expand = expand;
    inst.applyExpandedToToasts?.();
  }

  setActive(false);

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expand = btn.dataset.expand === 'true';
      setActive(expand);
      updatePreview(expand);
      applyExpandToToaster(expand);
      toast('Event has been created', {
        description: 'Monday, January 3rd at 6:00pm',
        ...getToastOpts(),
      });
    });
  });
</script>

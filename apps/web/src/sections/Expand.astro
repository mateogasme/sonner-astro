---
import ButtonOption from '../components/ButtonOption.astro';
import CodeBlock from '../components/CodeBlock.astro';
import P from '../components/P.astro';
import Title from '../components/Title.astro';
---

<section class="mt-14">
  <Title>Expand</Title>
  <P>You can change the amount of toasts visible through the <code style="font-family:inherit;background:hsl(0,0%,95%);border-radius:4px;padding:1px 5px;font-size:12px">visibleToasts</code> prop.</P>
  <div class="mt-4 flex flex-wrap gap-2">
    <ButtonOption data-expand="true">Expand</ButtonOption>
    <ButtonOption data-expand="false">Default</ButtonOption>
  </div>
  <div class="mt-4">
    <CodeBlock code="<Toaster expand={false} />" data-expand-preview />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { getToastOpts } from '../preview-state';

  const btns = document.querySelectorAll<HTMLElement>('[data-expand]');
  const preview = document.querySelector<any>('[data-expand-preview]');

  const ACTIVE_STYLE = { boxShadow: 'rgba(0,0,0,0.2) 0px 0px 0px 1.5px', background: '#f5f5f5' };
  const IDLE_STYLE   = { boxShadow: 'rgb(235,235,235) 0px 0px 0px 1px',   background: '#ffffff' };

  function setActive(activeExpand: boolean) {
    btns.forEach((b) => {
      const isThis = b.dataset.expand === String(activeExpand);
      Object.assign(b.style, isThis ? ACTIVE_STYLE : IDLE_STYLE);
    });
  }

  function updatePreview(expand: boolean) {
    preview?.setCode?.(`<Toaster expand={${expand}} />`);
  }

  function applyExpandToToaster(expand: boolean) {
    const root = document.querySelector<any>('section[data-sonner-root]');
    const inst = root?.__sonnerInstance as any;
    if (!inst) return;
    inst.opts.expand = expand;
    inst.applyExpandedToToasts?.();
  }

  // Default state: false
  setActive(false);

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expand = btn.dataset.expand === 'true';
      setActive(expand);
      updatePreview(expand);
      applyExpandToToaster(expand);
      toast('Event has been created', {
        description: 'Monday, January 3rd at 6:00pm',
        ...getToastOpts(),
      });
    });
  });
</script>

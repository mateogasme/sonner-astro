---
import ButtonOption from '../components/ButtonOption.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Title from '../components/Title.astro';
---

<section class="mt-14">
  <Title>Headless</Title>
  <div class="mt-4 flex flex-wrap gap-2">
    <ButtonOption data-headless-btn>Show headless toast</ButtonOption>
  </div>
  <div class="mt-4">
    <CodeBlock code={`toast.custom((id) => {\n  // your custom element\n  // call toast.dismiss(id) to close\n})`} />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { getToastOpts } from '../preview-state';

  document.querySelector('[data-headless-btn]')?.addEventListener('click', () => {
    toast.custom((id) => {
      const el = document.createElement('div');
      el.style.cssText =
        'background:#fff;border:1px solid hsl(0,0%,93%);border-radius:8px;padding:16px;display:flex;gap:12px;align-items:center;width:356px;box-shadow:0 4px 12px rgba(0,0,0,.1);font-size:13px;font-family:inherit;color:hsl(0,0%,9%)';
      el.innerHTML = `
        <div style="flex:1">
          <p style="margin:0;font-weight:500">Event Created</p>
          <p style="margin:4px 0 0;color:hsl(0,0%,50%);font-size:12px">Today at 4:00pm — Louvre Museum</p>
        </div>
        <button data-dismiss style="padding:4px 12px;border-radius:6px;border:none;background:#171717;color:#fff;font-size:12px;font-weight:500;cursor:pointer;font-family:inherit">Dismiss</button>
      `;
      el.querySelector('[data-dismiss]')?.addEventListener('click', () => toast.dismiss(id));
      return el;
    }, { ...getToastOpts() });
  });
</script>

---
import Title from '../components/Title.astro';
import P from '../components/P.astro';
import ButtonOption from '../components/ButtonOption.astro';
import CodeBlock from '../components/CodeBlock.astro';
---

<section class="mt-14">
  <Title>Other</Title>
  <P>Toggle options — they apply to every toast you fire.</P>
  <div class="mt-4 flex flex-wrap gap-2">
    <ButtonOption data-flag="richColors">Rich Colors</ButtonOption>
    <ButtonOption data-flag="closeButton">Close Button</ButtonOption>
    <ButtonOption data-flag="action">Action</ButtonOption>
    <ButtonOption data-flag="cancel">Cancel</ButtonOption>
    <ButtonOption data-other-custom>Custom</ButtonOption>
  </div>
  <div class="mt-4">
    <CodeBlock code="toast.success('Event has been created')" data-other-preview />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { toggleFlag, isOn, getToastOpts, toOptsCode } from '../preview-state';

  const ACTIVE_STYLE = { boxShadow: 'rgba(0,0,0,0.2) 0px 0px 0px 1.5px', background: '#f5f5f5' };
  const IDLE_STYLE   = { boxShadow: 'rgb(235,235,235) 0px 0px 0px 1px',   background: '#ffffff' };

  const preview = document.querySelector('[data-other-preview]');
  const codeEl  = preview?.querySelector('code');
  const copyBtn = preview?.querySelector<HTMLElement>('[data-copy-btn]');
  const flagBtns = document.querySelectorAll<HTMLElement>('[data-flag]');

  function syncButtonStyle(btn: HTMLElement, active: boolean) {
    Object.assign(btn.style, active ? ACTIVE_STYLE : IDLE_STYLE);
  }

  function updatePreview() {
    const code = `toast.success('Event has been created'${toOptsCode()})`;
    if (codeEl) codeEl.textContent = code;
    if (copyBtn) copyBtn.dataset.code = code;
  }

  flagBtns.forEach((btn) => {
    const key = btn.dataset.flag as any;
    syncButtonStyle(btn, isOn(key));

    btn.addEventListener('click', () => {
      const active = toggleFlag(key);
      syncButtonStyle(btn, active);
      updatePreview();
      toast.success('Event has been created', getToastOpts());
    });
  });

  // Custom: always a direct trigger, not a toggle
  document.querySelector('[data-other-custom]')?.addEventListener('click', () => {
    toast.custom((id) => {
      const el = document.createElement('div');
      el.style.cssText =
        'background:#fff;border:1px solid hsl(0,0%,93%);border-radius:8px;padding:16px;display:flex;gap:12px;align-items:center;width:356px;box-shadow:0 4px 12px rgba(0,0,0,.1);font-size:13px;font-family:inherit;color:hsl(0,0%,9%)';
      el.innerHTML = `
        <span style="font-weight:500;flex:1">Custom toast</span>
        <button data-dismiss style="padding:4px 12px;border-radius:6px;border:none;background:#171717;color:#fff;font-size:12px;font-weight:500;cursor:pointer;font-family:inherit">Dismiss</button>
      `;
      el.querySelector('[data-dismiss]')?.addEventListener('click', () => toast.dismiss(id));
      return el;
    });
  });
</script>

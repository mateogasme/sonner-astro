---
import ButtonOption from '../components/ButtonOption.astro';
import CodeBlock from '../components/CodeBlock.astro';
import P from '../components/P.astro';
import Title from '../components/Title.astro';
---

<section class="mt-14">
  <Title>Rich Colors</Title>
  <P>Control how much color the toast uses.</P>
  <div class="mt-4 flex flex-wrap gap-2">
    <ButtonOption data-color-mode="off">Off</ButtonOption>
    <ButtonOption data-color-mode="iconColors">Icon</ButtonOption>
    <ButtonOption data-color-mode="richBackground">Background</ButtonOption>
    <ButtonOption data-color-mode="richColors">Full</ButtonOption>
  </div>
  <div class="mt-4">
    <CodeBlock code={`<Toaster />`} data-rich-preview />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { setColorMode, getColorMode, getToastOpts } from '../preview-state';

  const preview  = document.querySelector<any>('[data-rich-preview]');
  const modeBtns = document.querySelectorAll<HTMLElement>('[data-color-mode]');

  const CODE: Record<string, string> = {
    off:            '<Toaster /> // without richColors prop',
    iconColors:     '<Toaster iconColors />',
    richBackground: '<Toaster richBackground />',
    richColors:     '<Toaster richColors />',
  };

  function syncButtons() {
    const mode = getColorMode();
    modeBtns.forEach((b) => { b.dataset.active = String(b.dataset.colorMode === mode); });
  }

  function updatePreview() {
    preview?.setCode?.(CODE[getColorMode()]);
  }

  syncButtons();
  requestAnimationFrame(() => updatePreview());

  modeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.colorMode as any;
      setColorMode(mode);
      syncButtons();
      updatePreview();
      toast.success('Event has been created', getToastOpts());
    });
  });

  window.addEventListener('sonner-preview-change', () => {
    syncButtons();
    updatePreview();
  });
</script>

---
import CodeBlock from '../components/CodeBlock.astro';
import P from '../components/P.astro';
import Title from '../components/Title.astro';
---

<section class="mt-14">
  <Title>Usage</Title>
  <P>Add the Toaster to your layout and call toast() from anywhere.</P>
  <div class="mt-4">
    <CodeBlock code={`---
import Toaster from 'sonner-astro/Toaster.astro';
import { toast } from 'sonner-astro';
---

<!-- Layout.astro -->
<body>
  <slot />
  <Toaster />
</body>

<!-- Any page or component -->
<button id="btn">Give me a toast</button>

<script>
  document.getElementById('btn').addEventListener('click', () => {
    toast('My first toast');
  });
</script>`} />
  </div>
</section>

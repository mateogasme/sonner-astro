---
import CodeBlock from '../components/CodeBlock.astro';
import P from '../components/P.astro';
import Title from '../components/Title.astro';
---

<section class="mt-14">
  <Title>Duration</Title>
  <P>Control how long toasts stay visible before auto-dismissing.</P>
  <div class="mt-4 flex flex-wrap gap-2">
    {[
      { label: '3s',  val: '3000'    },
      { label: '5s',  val: '5000'    },
      { label: '10s', val: '10000'   },
      { label: '∞',   val: 'Infinity'},
    ].map(({ label, val }) => (
      <button
        data-dur={val}
        style="font-size:13px;padding:5px 12px;border-radius:999px;cursor:pointer;font-family:inherit;border:none;transition:box-shadow 150ms,background 150ms;outline:none;box-shadow:rgb(235,235,235) 0px 0px 0px 1px;background:#ffffff"
      >{label}</button>
    ))}
  </div>
  <div class="mt-4">
    <CodeBlock code={`<Toaster duration={5000} />`} data-duration-preview />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { getDuration, setDuration, getToastOpts } from '../preview-state';

  const ACTIVE = { boxShadow: 'rgba(0,0,0,0.2) 0px 0px 0px 1.5px', background: '#f5f5f5' };
  const IDLE   = { boxShadow: 'rgb(235,235,235) 0px 0px 0px 1px',   background: '#ffffff' };

  const btns    = document.querySelectorAll<HTMLElement>('[data-dur]');
  const preview = document.querySelector<any>('[data-duration-preview]');

  function setActive(val: string) {
    btns.forEach((b) => Object.assign(b.style, b.dataset.dur === val ? ACTIVE : IDLE));
  }

  function updatePreview(val: string) {
    const display = val === 'Infinity' ? 'Infinity' : val;
    preview?.setCode?.(`<Toaster duration={${display}} />`);
  }

  const initialVal = getDuration() === Infinity ? 'Infinity' : String(getDuration());
  setActive(initialVal);
  requestAnimationFrame(() => updatePreview(initialVal));

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const val = btn.dataset.dur!;
      const ms = val === 'Infinity' ? Infinity : parseInt(val);
      setDuration(ms);
      setActive(val);
      updatePreview(val);
      toast('Event has been created', {
        description: 'Monday, January 3rd at 6:00pm',
        ...getToastOpts(),
      });
    });
  });
</script>

---
import ButtonOption from '../components/ButtonOption.astro';
import CodeBlock from '../components/CodeBlock.astro';
import P from '../components/P.astro';
import Title from '../components/Title.astro';
---

<section class="mt-14">
  <Title>Duration</Title>
  <P>Control how long toasts stay visible before auto-dismissing. The default duration is 5s.</P>
  <div class="mt-4 flex flex-wrap gap-2">
    <ButtonOption data-dur="3000">3s</ButtonOption>
    <ButtonOption data-dur="5000">5s</ButtonOption>
    <ButtonOption data-dur="10000">10s</ButtonOption>
    <ButtonOption data-dur="Infinity">∞</ButtonOption>
  </div>
  <div class="mt-4">
    <CodeBlock code={`<Toaster duration={5000} />`} data-duration-preview />
  </div>
</section>

<script>
  import { toast } from 'sonner-astro';
  import { getDuration, setDuration, getToastOpts } from '../preview-state';

  const btns    = document.querySelectorAll<HTMLElement>('[data-dur]');
  const preview = document.querySelector<any>('[data-duration-preview]');

  function setActive(val: string) {
    btns.forEach((b) => { b.dataset.active = String(b.dataset.dur === val); });
  }

  function updatePreview(val: string) {
    if (val === '5000') {
      preview?.setCode?.(`<Toaster duration={5000} /> // default`);
    } else {
      preview?.setCode?.(`<Toaster duration={${val}} />`);
    }
  }

  const initialVal = getDuration() === Infinity ? 'Infinity' : String(getDuration());
  setActive(initialVal);
  requestAnimationFrame(() => updatePreview(initialVal));

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const val = btn.dataset.dur!;
      const ms = val === 'Infinity' ? Infinity : parseInt(val);
      setDuration(ms);
      setActive(val);
      updatePreview(val);
      toast('Event has been created', {
        description: 'Monday, January 3rd at 6:00pm',
        ...getToastOpts(),
      });
    });
  });
</script>

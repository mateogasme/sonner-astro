---
const { class: className = '', ...rest } = Astro.props;
---

<button type="button" class:list={['btn-option', className]} {...rest}>
  <slot />
</button>

<style>
  .btn-option {
    user-select: none;
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border-radius: 9999px;
    background: var(--bg);
    color: var(--fg);
    font-family: inherit;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.43;
    text-decoration: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    box-shadow: var(--border) 0px 0px 0px 1px;
    transition:
      transform 160ms cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 160ms cubic-bezier(0.23, 1, 0.32, 1),
      background 160ms cubic-bezier(0.23, 1, 0.32, 1);
    outline: none;
  }

  .btn-option:focus-visible {
    outline: 2px solid hsla(212, 100%, 48%, 1);
    outline-offset: 2px;
  }

  .btn-option:active {
    transform: scale(0.97);
  }

  .btn-option[data-active="true"] {
    box-shadow: var(--btn-active-shadow);
    background: var(--surface);
  }

  @media (hover: hover) and (pointer: fine) {
    .btn-option:hover {
      box-shadow: var(--border-hover) 0px 0px 0px 1px;
      background: var(--surface);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-option {
      transition: none;
    }
    .btn-option:active {
      transform: none;
    }
  }
</style>

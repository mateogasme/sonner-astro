---
export interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const { href, type = 'button', class: className = '' } = Astro.props;
---

{href ? (
  <a href={href} class:list={['btn-secondary', className]}>
    <slot />
  </a>
) : (
  <button type={type} class:list={['btn-secondary', className]}>
    <slot />
  </button>
)}

<style>
  .btn-secondary {
    user-select: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 21px;
    border-radius: 9999px;
    background: var(--bg);
    color: var(--fg);
    font-family: inherit;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.43;
    letter-spacing: normal;
    text-decoration: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    box-shadow: var(--border) 0px 0px 0px 1px;
    transition:
      transform 160ms cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 160ms cubic-bezier(0.23, 1, 0.32, 1),
      background 160ms cubic-bezier(0.23, 1, 0.32, 1);
    outline: none;
  }

  .btn-secondary:focus-visible {
    outline: 2px solid hsla(212, 100%, 48%, 1);
    outline-offset: 2px;
  }

  .btn-secondary:active {
    transform: scale(0.97);
  }

  @media (hover: hover) and (pointer: fine) {
    .btn-secondary:hover {
      box-shadow: var(--border-hover) 0px 0px 0px 1px;
      background: var(--surface);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-secondary {
      transition: none;
    }
    .btn-secondary:active {
      transform: none;
    }
  }
</style>

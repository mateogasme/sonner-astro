---
import Toaster from 'sonner-astro/Toaster.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Sonner Astro — Test</title>
    <style>
      body { font-family: ui-sans-serif, system-ui, sans-serif; padding: 32px; background: #fafafa; }
      button { margin: 4px; padding: 8px 12px; border-radius: 6px; border: 1px solid #ddd; background: #fff; cursor: pointer; font-size: 13px; }
      button:hover { background: #f4f4f4; }
      h1 { font-size: 20px; }
    </style>
  </head>
  <body>
    <h1>Sonner Astro — Manual Test</h1>
    <div>
      <button id="b-default">toast()</button>
      <button id="b-success">success</button>
      <button id="b-error">error</button>
      <button id="b-warning">warning</button>
      <button id="b-info">info</button>
      <button id="b-loading">loading</button>
      <button id="b-promise">promise</button>
      <button id="b-action">action</button>
      <button id="b-cancel">cancel</button>
      <button id="b-desc">with description</button>
      <button id="b-custom">custom</button>
      <button id="b-dismiss-all">dismiss all</button>
      <button id="b-many">spawn 5</button>
    </div>

    <Toaster richColors closeButton position="bottom-right" />

    <script>
      import { toast } from 'sonner-astro';

      document.getElementById('b-default')!.onclick = () => toast('Event has been created');
      document.getElementById('b-success')!.onclick = () => toast.success('Saved successfully');
      document.getElementById('b-error')!.onclick = () => toast.error('Something went wrong');
      document.getElementById('b-warning')!.onclick = () => toast.warning('Be careful');
      document.getElementById('b-info')!.onclick = () => toast.info('FYI');
      document.getElementById('b-loading')!.onclick = () => toast.loading('Loading…');
      document.getElementById('b-promise')!.onclick = () => {
        const p = new Promise<{ name: string }>((res, rej) => setTimeout(() => Math.random() > 0.5 ? res({ name: 'File' }) : rej(new Error('nope')), 1500));
        toast.promise(p, {
          loading: 'Uploading…',
          success: (d) => `${d.name} uploaded`,
          error: (e) => `Failed: ${e.message}`,
        });
      };
      document.getElementById('b-action')!.onclick = () =>
        toast('Action available', {
          action: { label: 'Undo', onClick: () => console.log('undo') },
        });
      document.getElementById('b-cancel')!.onclick = () =>
        toast('Cancelable', {
          cancel: { label: 'Cancel', onClick: () => console.log('cancel') },
        });
      document.getElementById('b-desc')!.onclick = () =>
        toast.success('Title here', { description: 'Longer description text explains the context of the event.' });
      document.getElementById('b-custom')!.onclick = () =>
        toast.custom((id) => {
          const el = document.createElement('div');
          el.style.padding = '12px';
          el.style.background = 'linear-gradient(135deg,#7c3aed,#ec4899)';
          el.style.color = '#fff';
          el.style.borderRadius = '8px';
          el.style.width = '100%';
          el.textContent = `Custom #${id}`;
          return el;
        });
      document.getElementById('b-dismiss-all')!.onclick = () => toast.dismiss();
      document.getElementById('b-many')!.onclick = () => {
        for (let i = 0; i < 5; i++) setTimeout(() => toast(`Toast #${i + 1}`), i * 150);
      };
    </script>
  </body>
</html>
